{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DOCX Markdown Converter",
  "version": "0.1.0",
  "identifier": "com.local.docxmdconverter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DOCX / MD Converter",
        "width": 1010,
        "height": 605,
        "minWidth": 1010,
        "minHeight": 605,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
